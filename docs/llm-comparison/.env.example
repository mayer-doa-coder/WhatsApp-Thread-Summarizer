# Free LLM API Keys for comparison testing
# Copy this file to .env and fill in your keys
# ALL providers below are 100% free — no credit card needed

# ── Google AI Studio ─────────────────────────────────────
# Sign up: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Groq (Llama 4, GPT OSS, Qwen 3) ─────────────────────
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Cerebras (World's fastest inference, 100% free) ──────
# Sign up: https://cloud.cerebras.ai  → API Keys
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── OpenRouter (free-tier models, $0/token) ───────────────
# Sign up: https://openrouter.ai  → Keys  (no credit card)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── SambaNova (free tier, fast inference) ─────────────────
# Sign up: https://cloud.sambanova.ai  → API Key
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# ── DeepSeek (requires balance — NOT free) ────────────────
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
