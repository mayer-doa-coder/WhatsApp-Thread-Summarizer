# Server
PORT=4000
NODE_ENV=development

# ── Primary LLM — SambaNova (free tier) ──────────────────────────────────────
# Sign up: https://cloud.sambanova.ai → API Key
# Model: Llama-4-Maverick-17B-128E-Instruct
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# ── Fallback 1 — Cerebras (free tier, fastest inference) ─────────────────────
# Sign up: https://cloud.cerebras.ai → API Keys
# Model: llama3.1-8b
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Fallback 2 — Google AI Studio (free tier) ────────────────────────────────
# Sign up: https://aistudio.google.com/app/apikey
# Model: models/gemini-2.5-flash
GOOGLE_API_KEY=your_google_api_key_here

# ── Database — Supabase ───────────────────────────────────────────────────────
# Sign up: https://supabase.com → New Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-long-random-jwt-secret-here
